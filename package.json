{
    "name": "fks_react-ui",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "dependencies": {
        "@google-cloud/local-auth": "3.0.1",
        "@types/node": "24.3.0",
        "@types/react": "19.1.12",
        "@types/react-big-calendar": "1.16.2",
        "@types/react-dom": "19.1.9",
        "autoprefixer": "10.4.21",
        "axios": "1.11.0",
        "clsx": "2.1.1",
        "dayjs": "1.11.18",
        "framer-motion": "12.23.12",
        "google-auth-library": "10.3.0",
        "googleapis": "159.0.0",
        "lightweight-charts": "5.0.8",
        "lucide-react": "0.542.0",
        "mermaid": "11.10.1",
        "postcss": "8.5.6",
        "react": "19.1.1",
        "react-big-calendar": "1.19.4",
        "react-dom": "19.1.1",
        "react-hook-form": "7.62.0",
        "react-markdown": "10.1.0",
        "react-router-dom": "7.8.2",
        "recharts": "3.1.2",
        "socket.io-client": "4.8.1",
        "tailwind-merge": "3.3.1",
        "tailwindcss": "4.1.12",
        "typescript": "5.9.2",
        "zod": "4.1.5",
        "zustand": "5.0.8"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.12",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.8.0",
        "@testing-library/react": "16.3.0",
        "@testing-library/user-event": "14.6.1",
        "@typescript-eslint/eslint-plugin": "8.41.0",
        "@typescript-eslint/parser": "8.41.0",
        "@vitejs/plugin-react": "5.0.2",
        "@vitest/ui": "3.2.4",
        "eslint": "9.34.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-promise": "7.2.1",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-react-refresh": "0.4.20",
        "eslint-plugin-unused-imports": "4.2.0",
        "globals": "16.3.0",
        "jsdom": "26.1.0",
        "rollup-plugin-visualizer": "^5.12.0",
        "vite": "7.1.3",
    "vitest": "3.2.4",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
    },
    "scripts": {
        "predev": "node ./scripts/pre-run.cjs",
        "dev": "vite",
        "prestart": "node ./scripts/pre-run.cjs",
        "start": "vite",
        "prebuild": "node ./scripts/pre-run.cjs",
        "build": "tsc && vite build",
        "build:analyze": "tsc && vite build --mode analyze",
        "analyze:why": "npm run build && npx source-map-explorer 'dist/assets/*.js' --html",
        "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\" --max-warnings 200",
        "lint:strict": "eslint \"src/**/*.ts\" \"src/**/*.tsx\" --max-warnings 0",
        "lint:fix": "eslint \"src/**/*.ts\" \"src/**/*.tsx\" --fix",
        "lint:fix:imports": "eslint \"src/**/*.{ts,tsx}\" --rule 'import/order:warn' --fix",
        "lint:stats": "eslint \"src/**/*.{ts,tsx}\" -f json | node ./scripts/eslint-stats.cjs",
        "lint:changed": "git diff --name-only --diff-filter=ACMRT origin/main...HEAD | grep -E '\\.(ts|tsx)$' | xargs -r eslint",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "type-check": "tsc --noEmit",
        "deps:clean": "rm -rf node_modules package-lock.json && npm install --legacy-peer-deps",
        "deps:audit": "npm ls --depth=2 || true"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "proxy": "http://build-api:4000"
}
